# Copia este archivo a .env y completa los valores

# Orígenes permitidos para CORS (la URL de tu frontend en Netlify)
FRONTEND_ORIGIN=http://localhost:5173

# Ruta de la base de datos SQLite servida por la API
DATABASE_PATH=data/app.db

# --- Opcional: si migras a Supabase (Postgres + PostGIS) ---
# SUPABASE_URL=
# SUPABASE_KEY=
# DATABASE_URL=postgresql://user:pass@host:5432/postgres
